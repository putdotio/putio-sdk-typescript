# Example 1Password-backed env file for SDK live verification.
# Resolve with:
#   export OP_SERVICE_ACCOUNT_TOKEN="$OP_SERVICE_ACCOUNT_PUTIO_FRONTEND_CI"
#   op run --env-file=.env.1password.example -- <command>
#
# Adjust item IDs and field names to match your vault exactly.
# Prefer item IDs over titles when item titles contain characters like `+`.
# Verified field names in the current test vault:
#   - username
#   - password_confirmation
#   - one-time password

# Runtime tokens are currently persisted as JSON inside the runtime item's
# `notesPlain` field, not as dedicated per-token fields.
# PUTIO_1PASSWORD_RUNTIME_ITEM_ID="<runtime_item_id>"

PUTIO_TEST_USERNAME="op://<vault_id>/<ui_dev_item_id>/username"
PUTIO_TEST_PASSWORD="op://<vault_id>/<ui_dev_item_id>/password_confirmation"
PUTIO_TEST_TOTP="op://<vault_id>/<ui_dev_item_id>/one-time password"
PUTIO_TEST_TOTP_REFERENCE="op://<vault_id>/<ui_dev_item_id>/one-time password"

# Optional second account for positive invite/family flows.
# Keep this separate from the primary fixture account when possible.
# PUTIO_TEST_SECONDARY_USERNAME="op://<vault_id>/<secondary_item_id>/username"
# PUTIO_TEST_SECONDARY_PASSWORD="op://<vault_id>/<secondary_item_id>/password_confirmation"
# PUTIO_TEST_SECONDARY_TOTP="op://<vault_id>/<secondary_item_id>/one-time password"
# PUTIO_TEST_SECONDARY_TOTP_REFERENCE="op://<vault_id>/<secondary_item_id>/one-time password"

PUTIO_CLIENT_ID_FIRST_PARTY="op://<vault_id>/<official_client_item_id>/username"
PUTIO_CLIENT_SECRET_FIRST_PARTY="op://<vault_id>/<official_client_item_id>/password"

# Optional: if you already have an owned SDK test app, bootstrap will use it.
# Otherwise it creates or reuses a dedicated hidden app automatically.
# PUTIO_CLIENT_ID_THIRD_PARTY="op://<vault_id>/<third_party_client_item_id>/username"
